# Postgres — used by docker compose and DATABASE_URL
POSTGRES_USER=getnextbike
POSTGRES_PASSWORD=changeme
POSTGRES_DB=getnextbike

# DATABASE_URL — host inside compose network is `postgres`; locally use `localhost`
DATABASE_URL=postgres://getnextbike:changeme@postgres:5432/getnextbike

# Auth.js v5 — `openssl rand -base64 32` to generate
AUTH_SECRET=

# Anthropic (Phase 3+ — selector regen, catalog extraction)
ANTHROPIC_API_KEY=

# apps/web container — host port consumed by the host's Caddy
WEB_PORT=3000

# apps/worker — internal health port (not published)
WORKER_HEALTH_PORT=3100

# apps/worker — crawler scheduler
# Scheduler tick interval (ms); 0 disables auto-start
WORKER_TICK_MS=30000
# Max inventory items processed per tick across all storefronts
WORKER_BATCH_SIZE=50
# Default recrawl interval per inventory item (minutes); 360 = every 6h
INVENTORY_CRAWL_INTERVAL_MINUTES=360
# HTTP fetch timeout per page
WORKER_FETCH_TIMEOUT_MS=30000
# Identifier sent in the User-Agent header for crawler requests
WORKER_USER_AGENT=GetNextBikeBot/1.0 (+https://getnextbike.app)

# Snapshot storage (mounted Docker volume in prod, host bind in dev)
SNAPSHOTS_DIR=/var/lib/getnextbike/snapshots
# Files older than this are deleted on the hourly sweep (last success +
# last failure per item are pinned regardless)
SNAPSHOT_RETENTION_DAYS=7
WORKER_SWEEP_INTERVAL_MS=3600000
